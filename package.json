{
  "name": "teable-perf-lab",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "sync:cases": "node scripts/sync-perf-cases.mjs",
    "sync:readme": "node scripts/sync-readme-cases.mjs",
    "check:cases": "PERF_LAB_CASE_SYNC_DRY_RUN=true node scripts/sync-perf-cases.mjs",
    "check:readme": "node scripts/sync-readme-cases.mjs --check",
    "check:yaml": "node scripts/check-yaml.mjs",
    "check:trace": "node scripts/check-trace-classification.mjs && node scripts/check-trace-collector-exporter-outage.mjs",
    "check:catalog": "node scripts/check-catalog.mjs",
    "check:run-plan": "node scripts/check-run-plan.mjs",
    "check:artifact-read-model": "node scripts/check-perf-artifact-read-model.mjs",
    "check:run-summary-model": "node scripts/check-perf-run-summary-model.mjs",
    "check:report-requests": "node scripts/check-report-teable-result-requests.mjs",
    "check:artifact-diff-model": "node scripts/check-perf-artifact-diff-model.mjs",
    "check:record-read-model": "node --experimental-strip-types scripts/check-record-read-model.mjs",
    "check:record-create-model": "node --experimental-strip-types --test framework/runners/record-create-model.test.js",
    "check:record-update-model": "node --experimental-strip-types --test framework/runners/record-update-model.test.js",
    "check:perf-runtime-env": "node --experimental-strip-types --test framework/perf-runtime-env.test.js",
    "check:perf-error": "node --experimental-strip-types --test framework/perf-error.test.js",
    "check:case-sync-model": "node scripts/check-perf-case-sync-model.mjs",
    "check:case-sync-requests": "node scripts/check-perf-case-sync-requests.mjs",
    "check:conditional-query-workload": "node --experimental-strip-types --test framework/runners/conditional-query-workload.test.js",
    "check:conditional-lookup-record-create-model": "node --experimental-strip-types --test framework/runners/conditional-lookup-record-create-model.test.js",
    "check:link-computed-propagation-workload": "node --experimental-strip-types --test framework/runners/link-computed-propagation-workload.test.js",
    "check:computed-chain-mutation-model": "node --experimental-strip-types --test framework/runners/computed-chain-mutation-model.test.js",
    "check:customer-upsert-computed-flow-model": "node --experimental-strip-types --test framework/runners/customer-upsert-computed-flow-model.test.js",
    "check:field-add-lifecycle": "node --test framework/runners/field-add-lifecycle.test.js",
    "check:record-mutation-lifecycle": "node --test framework/runners/record-mutation-lifecycle.test.js",
    "check:table-lifecycle-model": "node --experimental-strip-types --test framework/runners/table-lifecycle-model.test.js",
    "check:ts": "node scripts/check-ts-syntax.mjs",
    "check:types": "node scripts/check-ts-types.mjs",
    "check": "pnpm format:check && pnpm check:yaml && pnpm check:ts && pnpm check:types && pnpm check:trace && pnpm check:catalog && pnpm check:run-plan && pnpm check:artifact-read-model && pnpm check:run-summary-model && pnpm check:report-requests && pnpm check:artifact-diff-model && pnpm check:record-read-model && pnpm check:record-create-model && pnpm check:record-update-model && pnpm check:perf-runtime-env && pnpm check:perf-error && pnpm check:case-sync-model && pnpm check:case-sync-requests && pnpm check:conditional-query-workload && pnpm check:conditional-lookup-record-create-model && pnpm check:link-computed-propagation-workload && pnpm check:computed-chain-mutation-model && pnpm check:customer-upsert-computed-flow-model && pnpm check:field-add-lifecycle && pnpm check:record-mutation-lifecycle && pnpm check:table-lifecycle-model && pnpm check:cases && pnpm check:readme"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "prettier": "3.6.2",
    "typescript": "5.9.2",
    "yaml": "2.8.1"
  }
}
