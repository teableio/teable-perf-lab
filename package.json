{
  "name": "teable-perf-lab",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
    "sync:cases": "node scripts/sync-perf-cases.mjs",
    "sync:readme": "node scripts/sync-readme-cases.mjs",
    "check:cases": "PERF_LAB_CASE_SYNC_DRY_RUN=true node scripts/sync-perf-cases.mjs",
    "check:readme": "node scripts/sync-readme-cases.mjs --check",
    "check:yaml": "node scripts/check-yaml.mjs",
    "check:trace": "node scripts/check-trace-classification.mjs",
    "check:catalog": "node scripts/check-catalog.mjs",
    "check:ts": "node scripts/check-ts-syntax.mjs",
    "check:types": "node scripts/check-ts-types.mjs",
    "check": "pnpm format:check && pnpm check:yaml && pnpm check:ts && pnpm check:types && pnpm check:trace && pnpm check:catalog && pnpm check:cases && pnpm check:readme"
  },
  "devDependencies": {
    "@types/node": "^22.19.20",
    "prettier": "3.6.2",
    "typescript": "5.9.2",
    "yaml": "2.8.1"
  }
}
